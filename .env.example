# FinTrack Pro — Environment Configuration
# Salin file ini menjadi .env dan sesuaikan nilainya.
# JANGAN commit file .env ke repository.

# Database
DB_HOST=localhost
DB_NAME=fintrack_pro
DB_USER=root
DB_PASS=

# Aplikasi
APP_URL=http://localhost/fintrack-pro
APP_ENV=development

# Google OAuth Login
# Redirect URI di Google Cloud Console harus sama dengan nilai ini.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/fintrack-pro/auth/google_callback.php